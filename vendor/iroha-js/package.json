{
  "name": "@iroha/iroha-js",
  "version": "0.0.2",
  "description": "Preview Node.js SDK for interacting with Hyperledger Iroha via Norito payloads and Torii APIs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./index.d.ts"
    },
    "./address": {
      "import": "./dist/address.js",
      "types": "./index.d.ts"
    },
    "./instruction-builders": {
      "import": "./dist/instructionBuilders.js",
      "types": "./index.d.ts"
    },
    "./torii": {
      "browser": "./dist/toriiBrowserClient.js",
      "import": "./dist/toriiClient.js",
      "types": "./index.d.ts"
    },
    "./torii-browser": {
      "import": "./dist/toriiBrowserClient.js",
      "browser": "./dist/toriiBrowserClient.js",
      "types": "./index.d.ts"
    },
    "./norito": "./dist/norito.js",
    "./canonical-request": {
      "import": "./dist/canonicalRequest.js",
      "types": "./index.d.ts"
    },
    "./sccp": {
      "import": "./dist/sccp.js",
      "types": "./index.d.ts"
    },
    "./crypto": {
      "browser": "./dist/crypto.browser.js",
      "import": "./dist/crypto.js",
      "types": "./index.d.ts"
    },
    "./connect-browser": {
      "import": "./dist/connect.browser.js",
      "types": "./connect.browser.d.ts"
    },
    "./nexus-app": {
      "import": "./dist/nexusApp.js",
      "types": "./nexus-app.d.ts"
    },
    "./kotodama-compiler": {
      "import": "./dist/kotodamaCompiler/index.js",
      "browser": "./dist/kotodamaCompiler/index.js",
      "types": "./kotodama-compiler.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "address": [
        "./index.d.ts"
      ],
      "instruction-builders": [
        "./index.d.ts"
      ],
      "torii": [
        "./index.d.ts"
      ],
      "torii-browser": [
        "./index.d.ts"
      ],
      "norito": [
        "./index.d.ts"
      ],
      "canonical-request": [
        "./index.d.ts"
      ],
      "sccp": [
        "./index.d.ts"
      ],
      "crypto": [
        "./index.d.ts"
      ],
      "connect-browser": [
        "./connect.browser.d.ts"
      ],
      "nexus-app": [
        "./nexus-app.d.ts"
      ],
      "kotodama-compiler": [
        "./kotodama-compiler.d.ts"
      ]
    }
  },
  "scripts": {
    "prepare": "echo skip",
    "lint": "eslint --max-warnings=0 src scripts recipes test --ext .js,.mjs",
    "lint:test": "npm run lint && npm run build:native && npm test",
    "build:native": "node ./scripts/build-native.mjs && node ./scripts/copy-native.mjs",
    "build:dist": "node ./scripts/build-dist.mjs",
    "bundle:check": "node ./scripts/bundle-size-check.mjs",
    "test": "npm run build:native && node --test",
    "test:dist": "npm run build:dist && node --test",
    "check:changelog": "node ./scripts/check-changelog.mjs",
    "release:update-docs": "node ./scripts/update-release-docs.mjs",
    "release:provenance": "node ./scripts/record-release-provenance.mjs",
    "release:verify": "node ./scripts/verify-release-tarball.mjs",
    "fixtures:axt": "node ./scripts/refresh-axt-fixtures.mjs",
    "release:matrix": "node ./scripts/release-matrix.mjs",
    "release:publish": "npm run check:changelog && npm run lint:test && npm run release:provenance && npm publish --access public --provenance",
    "prepublishOnly": "npm run check:changelog && npm run lint:test && npm run build:dist && npm run bundle:check",
    "test:integration": "node ./scripts/run_integration.mjs",
    "telemetry:capture": "node ./scripts/capture_sumeragi_telemetry.mjs",
    "report:bundle-size": "node ./scripts/report-bundle-size.mjs"
  },
  "keywords": [
    "iroha",
    "norito",
    "blockchain",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperledger-iroha/iroha.git",
    "directory": "javascript/iroha_js"
  },
  "bugs": {
    "url": "https://github.com/hyperledger-iroha/iroha/issues"
  },
  "homepage": "https://github.com/hyperledger-iroha/iroha/tree/master/javascript/iroha_js",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "README.md",
    "index.d.ts",
    "connect.browser.d.ts",
    "nexus-app.d.ts",
    "kotodama-compiler.d.ts",
    "package.json",
    "native/iroha_js_host.checksums.json",
    "dist",
    "recipes",
    "scripts",
    "src"
  ],
  "browser": {
    "./dist/crypto.js": "./dist/crypto.browser.js"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "license": "Apache-2.0",
  "private": false,
  "dependencies": {
    "@noble/ciphers": "^1.2.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.5.0",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  }
}
